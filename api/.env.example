DATABASE_URL=postgresql://user:pass@localhost:5432/rezervno

# ── تنظیم Connection Pool (مهم برای ترافیک بالا) ──
# در ترافیک بالا، بدون محدودیت pool، اتصال‌ها تمام می‌شوند و خطای ۵۰۰ می‌دهد.
# Postgres مدیریت‌شده سقف اتصال پایینی دارد (در تست ما روی Supabase: ۶۰).
# ⟶ از pooler (PgBouncer/Supabase Pooler/RDS Proxy) استفاده کن، نه اتصال مستقیم.
# مثال pooler (transaction mode، پورت ۶۵۴۳):
#   postgresql://user:pass@host:6543/db?pgbouncer=true&connection_limit=10&pool_timeout=10
# نکته: ?pgbouncer=true لازم است تا Prisma در transaction pooling درست کار کند.

# ── اتصال مستقیم (فقط برای migrate/db push، نه runtime) ──
# DATABASE_DIRECT_URL=postgresql://user:pass@host:5432/rezervno

# ── Read Replica (اختیاری) — کوئری‌های خواندنی سنگین به اینجا می‌روند ──
# اگر تنظیم نشود، dbRead خودکار به primary برمی‌گردد (بدون crash).
# DATABASE_REPLICA_URL=postgresql://user:pass@replica-host:6543/rezervno?pgbouncer=true

REDIS_URL=redis://localhost:6379
# رمز Redis (الزامی در production طبق docker-compose) — یک رشته‌ی تصادفی بلند
REDIS_PASSWORD=change-me-random-redis-password
# ── Redis Cluster (مقیاس بالا) — اگر تنظیم شود، حالت Cluster فعال و REDIS_URL نادیده گرفته می‌شود ──
# REDIS_CLUSTER_NODES=10.0.0.1:6379,10.0.0.2:6379,10.0.0.3:6379
JWT_SECRET=change-me-very-long-random-string
JWT_REFRESH_SECRET=change-me-too-different-random
# فاز ۲: KAVENEGAR_API_KEY / MELI_TOKEN
OTP_DEV_MODE=true   # true = کد OTP در پاسخ برمی‌گردد (فقط dev، بدون SMS واقعی)

# ── Observability (اختیاری) ──
# SENTRY_DSN: اگر تنظیم شود، خطاها و هشدارها به Sentry فرستاده می‌شوند
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# METRICS_TOKEN: اگر تنظیم شود، endpoint /api/metrics نیاز به Bearer token دارد
# METRICS_TOKEN=
# GRAFANA_PASSWORD: رمز ادمین Grafana (پیش‌فرض admin — حتماً عوض کن)
# GRAFANA_PASSWORD=
# LOG_LEVEL: debug|info|warn|error (پیش‌فرض: info در production)
# LOG_LEVEL=info

# ── پرداخت (Zarinpal) ──
# merchant_id/sandbox واقعی از پنل شرکت (platform_settings در DB) خوانده می‌شود؛
# این دو فقط fallback برای زمانی هستند که هنوز از پنل تنظیم نشده:
# ZARINPAL_MERCHANT_ID=
# ZARINPAL_SANDBOX=true
# CUSTOMER_APP_URL: آدرس اپ مشتری — بعد از بازگشت از درگاهِ زرین‌پال کاربر به
# ${CUSTOMER_APP_URL}/reservations/{code}?payment=paid|failed ریدایرکت می‌شود
# CUSTOMER_APP_URL=https://app.rezervno.ir

# ── CORS / origin مجاز (لازم برای فرانتِ دامنه‌ی جدا) ──
# دامنه‌های فرانت که مجازند بک‌اند را صدا بزنند (با کاما). هم چکِ CSRF و هم هدرهای
# CORS از این استفاده می‌کنند. اگر خالی باشد، fetchِ cross-origin بلاک می‌شود.
# مثال: ALLOWED_ORIGINS=https://rezervno.ir,https://www.rezervno.ir
# ALLOWED_ORIGINS=

# ═══════════════════════════════════════════════════════════
#  متغیرهای تکمیلی (مستندسازی‌شده در حسابرسیِ زیرساخت ۲۰۲۶-۰۷-۲۳)
#  این‌ها در کد استفاده می‌شدند ولی در این فایل مستند نبودند.
# ═══════════════════════════════════════════════════════════

# ── امنیت / عملیات ──
# CRON_SECRET: هدرِ احراز هویتِ endpointهای cron. مقایسه به‌صورت timing-safe انجام می‌شود.
# ⚠️ در production الزامی است؛ بدون آن endpointهای cron قابل فراخوانی نیستند.
# CRON_SECRET=change-me-long-random-string
# MAINTENANCE_KEY: کلیدِ اجرای عملیاتِ نگه‌داری دستی.
# MAINTENANCE_KEY=change-me-long-random-string
# TRUST_PROXY_HEADERS: پیش‌فرض true. فقط اگر پشتِ پراکسیِ مطمئن نیستی روی false بگذار
# (روی false، IP واقعی از هدرها خوانده نمی‌شود و rate-limit بر پایه‌ی IP سوکت کار می‌کند).
# TRUST_PROXY_HEADERS=true
# ALLOW_PRIVATE_WEBHOOKS: پیش‌فرض false. اجازه‌ی webhook به آدرس‌های شبکه‌ی داخلی
# (محافظت در برابر SSRF). فقط در محیطِ توسعه true کن.
# ALLOW_PRIVATE_WEBHOOKS=false

# ── پنل شرکت ──
# PLATFORM_ADMIN_TENANT_ID: UUID تنانتی که دسترسیِ ادمینِ پلتفرم دارد.
# PLATFORM_ADMIN_TENANT_ID=

# ── Connection Pool (تنظیم دقیق) ──
# DB_CONNECTION_LIMIT: سقفِ اتصالِ Prisma (پیش‌فرض: 10)
# DB_CONNECTION_LIMIT=10
# DB_POOL_TIMEOUT: مهلتِ گرفتنِ اتصال از pool به ثانیه (پیش‌فرض: 10)
# DB_POOL_TIMEOUT=10

# ── پیامک (Kavenegar) ──
# KAVENEGAR_API_KEY: بدون آن، ارسالِ پیامکِ واقعی غیرفعال است (OTP_DEV_MODE لازم می‌شود).
# KAVENEGAR_API_KEY=
# شناسه‌ی الگوهای پیامکی — هرکدام پیش‌فرضِ داخلی دارند؛ فقط اگر نامِ الگو در پنلِ
# کاوه‌نگار متفاوت است، اینجا override کن.
# KAVENEGAR_TPL_OTP=rezervno-otp
# KAVENEGAR_TPL_BOOKING=
# KAVENEGAR_TPL_REMINDER=
# KAVENEGAR_TPL_CANCELLED=
# KAVENEGAR_TPL_REJECTED=
# KAVENEGAR_TPL_PREPARING=
# KAVENEGAR_TPL_NOSHOW=
# KAVENEGAR_TPL_THANKS=
# KAVENEGAR_TPL_WELCOME=
# KAVENEGAR_TPL_WINBACK=
# KAVENEGAR_TPL_CAMPAIGN=
# KAVENEGAR_TPL_WAITLIST=
# KAVENEGAR_TPL_WL_JOIN=
# KAVENEGAR_TPL_WL_OFFER=

# ── ایمیل و پوش (اختیاری) ──
# EMAIL_API_KEY: بدون آن، ارسالِ ایمیل غیرفعال است.
# EMAIL_API_KEY=
# EMAIL_FROM=noreply@rezervno.ir
# FCM_SERVER_KEY: کلیدِ Firebase برای اعلانِ پوش. بدون آن، پوش غیرفعال است.
# FCM_SERVER_KEY=
