{
  "compilerOptions": {
    "target": "ES2022", "lib": ["dom", "ES2022"], "module": "esnext",
    "moduleResolution": "bundler", "strict": true, "skipLibCheck": true,
    "esModuleInterop": true, "jsx": "preserve", "incremental": true,
    "baseUrl": ".", "paths": { "@/*": ["src/*"] },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
