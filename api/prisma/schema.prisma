generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String       @id @default(uuid()) @db.Uuid
  name          String
  plan          SubscriptionPlan @default(free)
  planExpiresAt DateTime?    @map("plan_expires_at")
  trialEndsAt   DateTime?    @map("trial_ends_at")
  version       Int          @default(1)   // Optimistic Lock — جلوگیری از Lost Update در ویرایشِ همزمان
  createdAt     DateTime     @default(now()) @map("created_at")
  restaurants   Restaurant[]
  staff         Staff[]
  @@map("tenants")
}

// پلنِ اشتراک — enum به‌جای String: از ورودِ 'Pro'/'PRO'/فاصله جلوگیری می‌کند
enum SubscriptionPlan {
  free
  starter
  pro
  enterprise

  @@map("subscription_plan")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  phone        String        @unique
  email        String?       @unique                            // اختیاری؛ برای آینده: ورود ایمیلی، رسید، مارکتینگ
  firstName    String?       @map("first_name")
  lastName     String?       @map("last_name")
  birthDate    DateTime?     @map("birth_date") @db.Date
  anniversaryDate DateTime?  @map("anniversary_date") @db.Date  // سالگرد (برای پاداش)
  referralCode String?       @unique @map("referral_code")       // کد دعوت یکتای کاربر
  referredById String?       @map("referred_by_id") @db.Uuid     // چه کسی این کاربر را دعوت کرد
  avatarUrl    String?       @map("avatar_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  reservations Reservation[]
  memberships  ClubMember[]
  waitlistEntries WaitlistEntry[]
  pointsLedger PointsLedger[]
  referrals    Referral[]    @relation("Referrer")
  giftCardsPurchased GiftCard[] @relation("GiftBuyer")
  customerInsights CustomerInsight[]
  reviews      Review[]
  @@index([createdAt])
  @@map("users")
}

model Staff {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  phone    String
  role     StaffRole @default(staff)
  isActive Boolean @default(true) @map("is_active")  // غیرفعال‌سازی کارمند (اخراج) — توکن refreshش رد می‌شود
  permission StaffPermission?
  @@unique([tenantId, phone])
  @@map("staff")
}

model Restaurant {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  slug          String           @unique
  name          String
  cuisine       String?
  vibes         String[]         @default([])
  priceBand     Int              @default(2) @map("price_band") @db.SmallInt
  isOpen        Boolean          @default(true) @map("is_open")
  openingHours  Json?            @map("opening_hours")  // ساعت کاری هفتگی؛ null=همیشه باز طبق isOpen (سازگاری با گذشته)
  pricingRules  Json?            @map("pricing_rules")  // قواعدِ حداقل مبلغ رزرو بر اساس شلوغی (AI Pricing)
  baseMinSpendToman Int          @default(0) @map("base_min_spend_toman") // حداقل مبلغِ پایه
  // ── اتصال (heartbeat): برای پنهان‌کردن خودکار رستوران آفلاین از اپ مشتری ──
  lastSeenAt    DateTime?        @map("last_seen_at")   // آخرین heartbeat از پنل بیزنس
  onlineGating  Boolean          @default(true) @map("online_gating") // آیا رزرو آنلاین وابسته به آنلاین‌بودن است
  // ── پیکربندی زمان‌بندی رزرو (با پیش‌فرض امن — API نمی‌شکند) ──
  slotMinutes      Int @default(90) @map("slot_minutes") @db.SmallInt   // مدت پیش‌فرض هر رزرو
  bufferMinutes    Int @default(0)  @map("buffer_minutes") @db.SmallInt  // فاصله‌ی ایمنی بین رزروهای یک میز
  cleaningMinutes  Int @default(15) @map("cleaning_minutes") @db.SmallInt // زمان نظافت/چیدن میز
  lateGraceMinutes Int @default(15) @map("late_grace_minutes") @db.SmallInt // مهلت تأخیر مهمان قبل از no_show
  holdMinutes      Int @default(10) @map("hold_minutes") @db.SmallInt    // مدت هولد رزرو pending تا انقضا
  timezone      String           @default("Asia/Tehran")
  clubPrefix    String           @map("club_prefix")
  cbBasePct     Int              @default(5) @map("cb_base_pct") @db.SmallInt
  cbPreorderPct Int              @default(8) @map("cb_preorder_pct") @db.SmallInt
  cbVipPct      Int              @default(12) @map("cb_vip_pct") @db.SmallInt
  cbWinbackPct  Int              @default(20) @map("cb_winback_pct") @db.SmallInt
  smsBalance    Int              @default(0) @map("sms_balance")       // موجودی پیامک باقی‌مانده
  smsTotalSent  Int              @default(0) @map("sms_total_sent")    // کل پیامک ارسالی (آمار)
  createdAt     DateTime         @default(now()) @map("created_at")
  tables        Table[]
  menuItems     MenuItem[]
  reservations  Reservation[]
  members       ClubMember[]
  reviews       Review[]
  photos        RestaurantPhoto[]
  staffNotes    StaffNote[]
  campaignLogs  CampaignLog[]
  waitlist      WaitlistEntry[]
  specialEvents SpecialEvent[]
  codeCounter   ClubCodeCounter?
  customerInsights CustomerInsight[]
  coupons       Coupon[]
  marketingAutomations MarketingAutomation[]
  @@index([tenantId])
  @@map("restaurants")
}

// ── شکل میز (برای نقشه‌ی بصری و چیدمان) ──
enum TableShape {
  rectangle
  round
  booth                    // اتاقک/کابین
  @@map("table_shape")
}

// ── ناحیه‌ی میز (موقعیت اصلی) ──
enum TableZone {
  indoor                   // داخل سالن
  outdoor                  // فضای باز/حیاط
  window                   // کنار پنجره
  vip                      // بخش ویژه
  smoking                  // بخش سیگار
  @@map("table_zone")
}

// ── وضعیت لحظه‌ای میز (real-time) ──
enum TableState {
  free                     // آزاد
  reserved                 // رزروشده
  occupied                 // اشغال (مهمان نشسته)
  cleaning                 // در حال نظافت
  maintenance              // خارج از سرویس (تعمیر)
  @@map("table_state")
}

model Table {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @map("restaurant_id") @db.Uuid
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  number       Int           @db.SmallInt
  name         String?       // نام دلخواه میز (مثلاً «میز شاه‌نشین») — اختیاری
  capacity     Int           @db.SmallInt
  // ── محدوده‌ی ظرفیت (نیاز: Min/Max Party Size) ──
  minPartySize Int           @default(1) @map("min_party_size") @db.SmallInt
  maxPartySize Int?          @map("max_party_size") @db.SmallInt // پیش‌فرض = capacity اگر null
  // ── شکل و ناحیه (نیاز: Shape, VIP, Outdoor, Window, Smoking) ──
  shape        TableShape    @default(rectangle)
  zone         TableZone     @default(indoor)
  isVip        Boolean       @default(false) @map("is_vip")
  isSmoking    Boolean       @default(false) @map("is_smoking")
  isAccessible Boolean       @default(false) @map("is_accessible") // دسترس‌پذیر ویلچر
  // ── ترکیب/تقسیم (نیاز: Mergeable, Splittable) ──
  isMergeable  Boolean       @default(false) @map("is_mergeable")
  mergeableWith Int[]        @default([]) @map("mergeable_with") @db.SmallInt // شماره میزهای قابل‌ترکیب
  isSplittable Boolean       @default(false) @map("is_splittable")
  // ── چیدمان بصری (نیاز: Priority, Rotation) ──
  priority     Int           @default(0) @db.SmallInt // اولویت در تخصیص هوشمند (بالاتر = ترجیح بیشتر)
  posX         Int?          @map("pos_x") @db.SmallInt // مختصات روی نقشه‌ی سالن
  posY         Int?          @map("pos_y") @db.SmallInt
  rotation     Int           @default(0) @db.SmallInt // چرخش (درجه) روی نقشه
  // ── محدودیت زمانی (نیاز: Maximum Duration) ──
  maxDurationMinutes Int?    @map("max_duration_minutes") @db.SmallInt // سقف مدت رزرو این میز
  // ── وضعیت لحظه‌ای (نیاز: Cleaning/Occupied/Reserved/Maintenance) ──
  state        TableState    @default(free)
  isActive     Boolean       @default(true) @map("is_active") // میز در دسترس رزرو است؟
  // ── کد QR برای check-in سر میز (نیاز: QR Code) ──
  qrCode       String?       @unique @map("qr_code")
  attributes   String[]      @default([]) // ویژگی‌های آزاد اضافی
  reservations Reservation[]
  @@unique([restaurantId, number])
  @@index([restaurantId, isActive, capacity])
  @@index([restaurantId, state])
  @@index([restaurantId, zone])
  @@map("tables")
}

model MenuItem {
  id           String            @id @default(uuid()) @db.Uuid
  restaurantId String            @map("restaurant_id") @db.Uuid
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  name         String
  emoji        String?
  priceToman   Int               @map("price_toman")
  isActive     Boolean           @default(true) @map("is_active")
  soldCount    Int               @default(0) @map("sold_count")
  inOrders     ReservationItem[]
  // کوئری منو: آیتم‌های فعال یک رستوران
  @@index([restaurantId, isActive])
  @@map("menu_items")
}

enum ReservationStatus {
  // ── چرخه‌ی حیات کامل رزرو ──
  pending                  // در انتظار تأیید (هولد موقت)
  waitlisted               // در لیست انتظار (ظرفیت پر بود)
  confirmed                // تأییدشده (دستی توسط رستوران/مشتری)
  auto_confirmed           // تأیید خودکار (سیستم)
  preparing                // در حال آماده‌سازی میز (نزدیک زمان رزرو)
  checked_in               // مهمان رسیده و check-in کرده
  running_late             // مهمان دیر کرده (از زمان گذشته، هنوز نرسیده)
  seated                   // سر میز نشسته
  dining                   // در حال صرف غذا
  completed                // تمام‌شده (مهمان رفت)
  no_show                  // مهمان نیامد
  rejected                 // ردشده توسط رستوران (قبل از تأیید)
  expired                  // هولد منقضی شد
  cancelled                // لغوشده (کلی)
  auto_cancelled           // لغو خودکار (سیستم — مثلاً waitlist که جا باز نشد)
  // ── وضعیت‌های قدیمی (حفظ‌شده برای سازگاری داده‌ی موجود) ──
  arrived                  // [قدیمی] معادل checked_in
  cancelled_by_user        // [قدیمی] معادل cancelled (توسط مشتری)
  cancelled_by_restaurant  // [قدیمی] معادل cancelled (توسط رستوران)
  @@map("reservation_status")
}

model Reservation {
  id           String            @id @default(uuid()) @db.Uuid
  code         String            @unique
  restaurantId String            @map("restaurant_id") @db.Uuid
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  tableId      String?           @map("table_id") @db.Uuid
  table        Table?            @relation(fields: [tableId], references: [id])
  userId       String?           @map("user_id") @db.Uuid
  user         User?             @relation(fields: [userId], references: [id])
  guestName    String?           @map("guest_name")
  guestPhone   String?           @map("guest_phone")
  partySize    Int               @map("party_size") @db.SmallInt
  slotStart    DateTime          @map("slot_start")
  slotEnd      DateTime          @map("slot_end")
  status       ReservationStatus @default(confirmed)
  source       String            @default("app")
  preferences  String[]          @default([])
  note         String?
  cancelReason String?           @map("cancel_reason")
  // ── انقضای هولد: رزرو pending که تا این زمان تأیید نشود، expired می‌شود ──
  holdExpiresAt DateTime?        @map("hold_expires_at")
  // ── میزهای ترکیبی (merge): اگر گروه روی چند میز نشسته، شماره‌ی همه اینجاست ──
  mergedTableNumbers Int[]       @default([]) @map("merged_table_numbers") @db.SmallInt
  // ── مدت واقعی این رزرو (دقیقه) — از پیکربندی رستوران یا override ──
  durationMinutes Int?          @map("duration_minutes") @db.SmallInt
  // ── ریسک no-show (فاز v2 — هوش مشتری) ──
  noShowRiskScore  Int?         @map("no_show_risk_score") @db.SmallInt
  noShowRiskTier   String?      @map("no_show_risk_tier")
  depositRequested Boolean      @default(false) @map("deposit_requested")
  createdAt    DateTime          @default(now()) @map("created_at")
  items        ReservationItem[]
  events       ReservationEvent[]
  reviews      Review[]
  // ── ایندکس‌های بهینه برای ۱۰M+ رزرو (بر اساس الگوی واقعی کوئری) ──
  // داشبورد رستوران: رزروهای یک رستوران در بازه‌ی زمانی با وضعیت
  @@index([restaurantId, status, slotStart])
  // کوئری تداخل میز (موتور رزرو + availability)
  @@index([tableId, status, slotStart, slotEnd])
  // تاریخچه‌ی کاربر: رزروهای یک کاربر، جدیدترین اول
  @@index([userId, slotStart(sort: Desc)])
  // پاکسازی هولدهای منقضی (partial-friendly)
  @@index([status, holdExpiresAt])
  // گزارش‌های زمانی و تحلیل (رزروهای ثبت‌شده در بازه)
  @@index([restaurantId, createdAt])
  @@index([restaurantId, noShowRiskTier, slotStart])
  @@map("reservations")
}

model ReservationItem {
  reservationId String      @map("reservation_id") @db.Uuid
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  menuItemId    String      @map("menu_item_id") @db.Uuid
  // Restrict: آیتم منویی که در سابقه‌ی سفارش هست نباید حذف شود (یکپارچگی تاریخچه)
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  qty           Int         @default(1) @db.SmallInt
  @@id([reservationId, menuItemId])
  // برای آمار «پرفروش‌ترین آیتم‌ها»
  @@index([menuItemId])
  @@map("reservation_items")
}

// ── لاگ رویداد رزرو (audit log) — هر تغییر وضعیت اینجا ثبت می‌شود ──
model ReservationEvent {
  id            String      @id @default(uuid()) @db.Uuid
  reservationId String      @map("reservation_id") @db.Uuid
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  fromStatus    ReservationStatus? @map("from_status") // وضعیت قبلی (null برای رویداد اول)
  toStatus      ReservationStatus  @map("to_status")   // وضعیت جدید
  actor         String      @default("system")         // چه کسی: system | customer | staff:{id} | cron
  reason        String?                                // دلیل (اختیاری)
  isAutomatic   Boolean     @default(false) @map("is_automatic") // انتقال خودکار بود؟
  createdAt     DateTime    @default(now()) @map("created_at")
  @@index([reservationId, createdAt])
  @@map("reservation_events")
}

// ── وضعیت ورودی لیست انتظار ──
enum WaitlistStatus {
  waiting                  // در صف انتظار
  offered                  // میز آزاد شد، آفر داده شده (منتظر پاسخ مشتری)
  accepted                 // مشتری آفر را پذیرفت → رزرو ساخته می‌شود
  declined                 // مشتری آفر را رد کرد
  expired                  // مهلت پاسخ به آفر گذشت
  seated                   // مشتری نشست (تکمیل)
  cancelled                // مشتری از صف خارج شد
  no_response              // آفر بدون پاسخ منقضی شد (متفاوت از declined)
  @@map("waitlist_status")
}

model WaitlistEntry {
  id              String         @id @default(uuid()) @db.Uuid
  restaurantId    String         @map("restaurant_id") @db.Uuid
  restaurant      Restaurant     @relation(fields: [restaurantId], references: [id])
  userId          String?        @map("user_id") @db.Uuid
  user            User?          @relation(fields: [userId], references: [id])
  // اطلاعات مهمان (برای ورودی بدون حساب)
  guestName       String?        @map("guest_name")
  guestPhone      String?        @map("guest_phone")
  guestEmail      String?        @map("guest_email")
  partySize       Int            @map("party_size") @db.SmallInt
  // ── اولویت صف (بالاتر = جلوتر). VIP و باشگاه طلایی امتیاز می‌گیرند ──
  priority        Int            @default(0) @db.SmallInt
  isVip           Boolean        @default(false) @map("is_vip")
  status          WaitlistStatus @default(waiting)
  // ── زمان‌ها ──
  joinedAt        DateTime       @default(now()) @map("joined_at")
  offeredAt       DateTime?      @map("offered_at")        // کِی آفر داده شد
  offerExpiresAt  DateTime?      @map("offer_expires_at")  // مهلت پاسخ (تایمر انقضا)
  respondedAt     DateTime?      @map("responded_at")
  seatedAt        DateTime?      @map("seated_at")
  // ── تخصیص میز هنگام آفر ──
  offeredTableId  String?        @map("offered_table_id") @db.Uuid
  offeredTableNumber Int?        @map("offered_table_number") @db.SmallInt
  // ── تخمین زمان انتظار (دقیقه) — هنگام پیوستن محاسبه و ذخیره می‌شود ──
  estimatedWaitMinutes Int?      @map("estimated_wait_minutes") @db.SmallInt
  // ── کانال‌های اعلان دلخواه ──
  notifySms       Boolean        @default(true) @map("notify_sms")
  notifyPush      Boolean        @default(true) @map("notify_push")
  notifyEmail     Boolean        @default(false) @map("notify_email")
  // رزرو ساخته‌شده پس از accept (در صورت وجود)
  reservationCode String?        @map("reservation_code")
  note            String?
  createdAt       DateTime       @default(now()) @map("created_at")
  @@index([restaurantId, status, priority(sort: Desc), joinedAt])
  @@index([status, offerExpiresAt])
  @@index([userId, status])
  @@map("waitlist_entries")
}

// ── دفتر امتیاز (تاریخچه‌ی کسب/خرج امتیاز وفاداری) ──
enum PointsReason {
  reservation              // امتیاز بابت رزرو تکمیل‌شده
  referral                 // امتیاز بابت دعوت دوست
  birthday                 // هدیه‌ی تولد
  anniversary              // هدیه‌ی سالگرد
  signup                   // امتیاز خوش‌آمد
  cashback                 // کش‌بک خرید (pre-order) — checkout
  redemption               // خرج امتیاز (پاداش)
  adjustment               // تنظیم دستی
  @@map("points_reason")
}

model PointsLedger {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  user         User         @relation(fields: [userId], references: [id])
  restaurantId String?      @map("restaurant_id") @db.Uuid
  delta        Int          // مثبت = کسب، منفی = خرج
  reason       PointsReason
  note         String?
  createdAt    DateTime     @default(now()) @map("created_at")
  @@index([userId, createdAt])
  // NEW-M1: unique partial index روی (user_id, reason, year) برای reason های
  // birthday/anniversary در migration 013 ساخته می‌شود (Prisma بیان expression-based
  // را پشتیبانی نمی‌کند). جلوگیری از پاداش سالانه‌ی دوگانه تحت همزمانی.
  @@map("points_ledger")
}

// ── دعوت دوستان (Referral) ──
enum ReferralStatus {
  pending                  // دعوت‌شده ثبت‌نام نکرده
  completed                // ثبت‌نام و اولین رزرو انجام شد → پاداش
  rewarded                 // پاداش پرداخت شد
  @@map("referral_status")
}

model Referral {
  id           String         @id @default(uuid()) @db.Uuid
  referrerId   String         @map("referrer_id") @db.Uuid
  referrer     User           @relation("Referrer", fields: [referrerId], references: [id])
  inviteePhone String         @map("invitee_phone")  // شماره‌ی دعوت‌شده
  inviteeId    String?        @map("invitee_id") @db.Uuid // وقتی ثبت‌نام کرد
  status       ReferralStatus @default(pending)
  rewardPoints Int            @default(500) @map("reward_points")
  createdAt    DateTime       @default(now()) @map("created_at")
  completedAt  DateTime?      @map("completed_at")
  @@index([referrerId, status])
  @@index([inviteePhone])
  @@map("referrals")
}

// ── کارت هدیه (Gift Card) ──
enum GiftCardStatus {
  active                   // فعال، قابل‌استفاده
  redeemed                 // استفاده‌شده (کامل)
  expired                  // منقضی
  @@map("gift_card_status")
}

model GiftCard {
  id           String         @id @default(uuid()) @db.Uuid
  code         String         @unique  // کد یکتای کارت هدیه
  buyerId      String?        @map("buyer_id") @db.Uuid
  buyer        User?          @relation("GiftBuyer", fields: [buyerId], references: [id])
  restaurantId String?        @map("restaurant_id") @db.Uuid  // null = قابل‌استفاده همه‌جا
  amountToman  Int            @map("amount_toman")
  balanceToman Int            @map("balance_toman")  // مانده (برای استفاده‌ی جزئی)
  recipientName  String?      @map("recipient_name")
  recipientPhone String?      @map("recipient_phone")
  message      String?        // پیام هدیه
  status       GiftCardStatus @default(active)
  expiresAt    DateTime?      @map("expires_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  @@index([recipientPhone])
  @@index([buyerId])
  @@map("gift_cards")
}

// ── رویدادهای ویژه (Special Events) — شب موسیقی، منوی ویژه و... ──
model SpecialEvent {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  title        String
  description  String?
  emoji        String?    // آیکون نمایشی
  startsAt     DateTime   @map("starts_at")
  endsAt       DateTime?  @map("ends_at")
  priceToman   Int?       @map("price_toman")  // قیمت بلیت (اگر دارد)
  capacity     Int?       // ظرفیت
  isPublished  Boolean    @default(true) @map("is_published")
  createdAt    DateTime   @default(now()) @map("created_at")
  @@index([restaurantId, startsAt])
  @@index([isPublished, startsAt])
  @@map("special_events")
}

model ClubMember {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  userId       String     @map("user_id") @db.Uuid
  user         User       @relation(fields: [userId], references: [id])
  code         String
  tier         String     @default("bronze")
  points       Int        @default(0)
  joinedAt     DateTime   @default(now()) @map("joined_at")
  @@unique([restaurantId, userId])
  @@unique([restaurantId, code])
  // کمپین SMS و آمار باشگاه: اعضای یک رستوران بر اساس سطح
  @@index([restaurantId, tier])
  @@map("club_members")
}

model ClubCodeCounter {
  restaurantId String     @id @map("restaurant_id") @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  nextValue    Int        @default(1001) @map("next_value")
  @@map("club_code_counters")
}

model OtpCode {
  phone     String   @id
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  // برای پاکسازی دوره‌ای کدهای منقضی
  @@index([expiresAt])
  @@map("otp_codes")
}


// ═══════════════════════════════════════════════════════════════════════
//  فاز v2 — هوش مشتری، کوپن، کمپین خودکار، RBAC
// ═══════════════════════════════════════════════════════════════════════

// ───────────────────────────────────────────────────────────────────────
//  ۱) CustomerInsight — CLV + ریسک no-show + سگمنت، per (رستوران × کاربر)
//     محاسبه‌شده توسط cron شبانه (maintenance/customer-insights) +
//     به‌روزرسانی فوری بعد از هر completed/no_show.
// ───────────────────────────────────────────────────────────────────────
enum CustomerSegment {
  new_customer      // اولین بازدید یا بدون بازدید قبلی
  active            // بازدید منظم، فاصله‌ی کم
  at_risk           // قبلاً منظم بود، مدتی غیبت کرده
  churned           // مدت طولانی غیبت (بر اساس میانگین فاصله‌ی بازدید رستوران)
  vip               // بالاترین دهک CLV این رستوران
  @@map("customer_segment")
}

model CustomerInsight {
  restaurantId      String          @map("restaurant_id") @db.Uuid
  restaurant        Restaurant      @relation(fields: [restaurantId], references: [id])
  userId            String          @map("user_id") @db.Uuid
  user              User            @relation(fields: [userId], references: [id])

  // ── CLV ──
  totalVisits       Int             @default(0) @map("total_visits")
  totalSpendToman   Int             @default(0) @map("total_spend_toman")     // جمع پیش‌سفارش‌ها (واقعی)
  avgSpendToman     Int             @default(0) @map("avg_spend_toman")
  visitFrequencyDays Float?         @map("visit_frequency_days")              // میانگین فاصله‌ی بازدید
  predictedClvToman Int             @default(0) @map("predicted_clv_toman")   // پیش‌بینی ۱۲ ماه آینده
  firstVisitAt      DateTime?       @map("first_visit_at")
  lastVisitAt       DateTime?       @map("last_visit_at")

  // ── ریسک رفتاری ──
  noShowCount       Int             @default(0) @map("no_show_count")
  cancelCount       Int             @default(0) @map("cancel_count")
  completedCount    Int             @default(0) @map("completed_count")
  noShowRatePct     Int             @default(0) @map("no_show_rate_pct")      // ۰..۱۰۰
  churnRiskScore    Int             @default(0) @map("churn_risk_score")     // ۰..۱۰۰ (بالاتر = خطر بیشتر)
  rScore            Int?            @map("r_score") @db.SmallInt             // RFM Recency 1..5
  fScore            Int?            @map("f_score") @db.SmallInt             // RFM Frequency 1..5
  mScore            Int?            @map("m_score") @db.SmallInt             // RFM Monetary 1..5
  rfmSegment        String?         @map("rfm_segment")                      // champions/loyal/at_risk/hibernating/...

  segment           CustomerSegment @default(new_customer)
  isVip             Boolean         @default(false) @map("is_vip")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@id([restaurantId, userId])
  // داشبورد: مرتب‌سازی بر اساس CLV یا فیلتر سگمنت
  @@index([restaurantId, segment, predictedClvToman(sort: Desc)])
  @@index([restaurantId, churnRiskScore(sort: Desc)])
  @@map("customer_insights")
}

// ───────────────────────────────────────────────────────────────────────
//  ۲) Coupon Engine — مستقل از کش‌بک درصدی فعلی
// ───────────────────────────────────────────────────────────────────────
enum CouponKind {
  percent           // درصدی (مثلاً ۲۰٪)
  fixed             // مقدار ثابت تومانی
  free_item         // آیتم رایگان (menuItemId)
  @@map("coupon_kind")
}

model Coupon {
  id            String      @id @default(uuid()) @db.Uuid
  restaurantId  String      @map("restaurant_id") @db.Uuid
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  code          String      // کد قابل‌نمایش (مثلاً WELCOME20)
  kind          CouponKind
  value         Int         // درصد یا تومان (برای free_item بی‌اثر)
  freeMenuItemId String?    @map("free_menu_item_id") @db.Uuid
  // ── محدودیت‌ها ──
  minPartySize  Int?        @map("min_party_size") @db.SmallInt
  maxRedemptions Int?       @map("max_redemptions")          // null = نامحدود
  redemptionCount Int       @default(0) @map("redemption_count")
  perUserLimit  Int         @default(1) @map("per_user_limit")
  // ── هدف‌گیری (نیاز Campaign Manager) — اگر پر باشد، کوپن فقط برای این سگمنت فعال است ──
  targetSegment CustomerSegment?
  validFrom     DateTime    @default(now()) @map("valid_from")
  validUntil    DateTime?   @map("valid_until")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  redemptions   CouponRedemption[]
  @@unique([restaurantId, code])
  @@index([restaurantId, isActive, validUntil])
  @@map("coupons")
}

model CouponRedemption {
  id            String      @id @default(uuid()) @db.Uuid
  couponId      String      @map("coupon_id") @db.Uuid
  coupon        Coupon      @relation(fields: [couponId], references: [id])
  userId        String?     @map("user_id") @db.Uuid
  reservationCode String?   @map("reservation_code")
  discountToman Int         @map("discount_toman")
  ip            String?                              // برای تشخیص سوءاستفاده‌ی چند‌حسابی (fraud)
  redeemedAt    DateTime    @default(now()) @map("redeemed_at")
  @@index([couponId, userId])
  @@map("coupon_redemptions")
}

// ───────────────────────────────────────────────────────────────────────
//  ۳) Marketing Automation — کمپین‌های خودکار trigger-based
//     (متفاوت از کمپین دستی فعلی در sms route — این‌ها رویداد-محورند)
// ───────────────────────────────────────────────────────────────────────
enum AutomationTrigger {
  birthday          // N روز قبل از تولد مشتری
  winback           // مشتری از segment=at_risk به churned نزدیک می‌شود
  post_visit        // X ساعت بعد از completed (نظرسنجی/تشکر)
  vip_milestone     // مشتری به سگمنت vip ارتقا یافت
  no_show_followup  // بعد از no_show (پیشنهاد بازگشت با تخفیف)
  @@map("automation_trigger")
}

model MarketingAutomation {
  id            String             @id @default(uuid()) @db.Uuid
  restaurantId  String             @map("restaurant_id") @db.Uuid
  restaurant    Restaurant         @relation(fields: [restaurantId], references: [id])
  name          String
  trigger       AutomationTrigger
  // پارامتر trigger (مثلاً {"daysBefore":3} برای birthday یا {"hoursAfter":2} برای post_visit)
  triggerConfig Json               @default("{}") @map("trigger_config")
  messageTemplate String           @map("message_template")   // فقط برای پیش‌نمایش در پنل؛ ارسال واقعی از قالب ثابت Kavenegar (campaign/winback_offer) با توکن انجام می‌شود
  couponId      String?            @map("coupon_id") @db.Uuid // کوپن خودکار پیوست‌شده (اختیاری)
  isActive      Boolean            @default(true) @map("is_active")
  lastRunAt     DateTime?          @map("last_run_at")
  sentCount     Int                @default(0) @map("sent_count")
  convertedCount Int               @default(0) @map("converted_count")  // چند نفر بعدش رزرو کردند
  createdAt     DateTime           @default(now()) @map("created_at")
  @@index([restaurantId, isActive, trigger])
  @@map("marketing_automations")
}

// ───────────────────────────────────────────────────────────────────────
//  ۴) Staff Permissions — RBAC ماژولار، مکمل role ساده‌ی فعلی
//     role فعلی (owner/manager/staff) دست‌نخورده می‌ماند؛ این جدول override می‌دهد.
// ───────────────────────────────────────────────────────────────────────
model StaffPermission {
  staffId         String   @id @map("staff_id") @db.Uuid
  staff           Staff    @relation(fields: [staffId], references: [id])
  // پیش‌فرض همه‌چیز false برای staff عادی؛ owner/manager در کد همیشه true می‌گیرند
  canManageReservations Boolean @default(true)  @map("can_manage_reservations")
  canManageTables       Boolean @default(true)  @map("can_manage_tables")
  canManageWaitlist     Boolean @default(true)  @map("can_manage_waitlist")
  canViewAnalytics      Boolean @default(false) @map("can_view_analytics")
  canViewRevenue        Boolean @default(false) @map("can_view_revenue")     // حساس‌ترین: درآمد مالی
  canManageCampaigns    Boolean @default(false) @map("can_manage_campaigns")
  canManageCoupons      Boolean @default(false) @map("can_manage_coupons")
  canManageStaff        Boolean @default(false) @map("can_manage_staff")
  canManageSettings     Boolean @default(false) @map("can_manage_settings")
  updatedAt             DateTime @updatedAt @map("updated_at")
  @@map("staff_permissions")
}

// ── Audit Log عمومی برای رویدادهای امنیتی/حاکمیتی (observability) ──
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  action       String                                   // مثل 'auth.failure'، 'staff.permission_change'
  actorId      String?  @map("actor_id") @db.Uuid
  actorType    String   @default("anonymous") @map("actor_type")
  targetId     String?  @map("target_id") @db.Uuid
  restaurantId String?  @map("restaurant_id") @db.Uuid
  ip           String?
  traceId      String?  @map("trace_id")
  success      Boolean  @default(true)
  detail       Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([restaurantId, createdAt])
  @@map("audit_logs")
}

// ── صف Job عمومی (Postgres-based با FOR UPDATE SKIP LOCKED) ──
// برای انتقال پردازش‌های سنگین/کند به پس‌زمینه: SMS، Email، Push، Report، Image.
// تست‌شده روی PostgreSQL واقعی: claim اتمیک، priority، retry+backoff، DLQ، idempotency.
enum JobStatus {
  pending
  processing
  completed
  failed
  dead      // dead-letter: بعد از اتمام تلاش‌ها

  @@map("job_status")
}

// نقشِ پرسنل — enum به‌جای String: از ورودِ 'Admin'/'ADMIN' نامعتبر جلوگیری می‌کند
enum StaffRole {
  owner
  manager
  staff
  admin

  @@map("staff_role")
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  kind           String                                    // 'sms'|'email'|'push'|'report'|'image'
  payload        Json      @default("{}")
  priority       Int       @default(5) @db.SmallInt        // 1=بالاترین ... 9=پایین‌ترین
  status         JobStatus @default(pending)
  idempotencyKey String?   @unique @map("idempotency_key")  // جلوگیری از کار تکراری (dedup به این وابسته است)
  attempts       Int       @default(0) @db.SmallInt
  maxAttempts    Int       @default(5) @map("max_attempts") @db.SmallInt
  runAfter       DateTime  @default(now()) @map("run_after") // برای backoff
  lastError      String?   @map("last_error")
  lockedAt       DateTime? @map("locked_at")
  result         Json?                                      // خروجی کار (اختیاری)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status, priority, runAfter])
  @@map("jobs")
}

// ── Idempotency سطح HTTP — جلوگیری از double-submit (رزرو/پرداخت) ──
model IdempotencyKey {
  key       String   @id
  scope     String                                 // 'reservation' و غیره
  response  Json?                                  // پاسخ cache‌شده‌ی اولین درخواست موفق
  status    String   @default("in_progress")       // in_progress | done
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ── Webhook خروجی — ادغام شخص ثالث (POS، حسابداری، Zapier) ──
model Webhook {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  url          String
  events       String[]                              // رویدادهایی که این webhook می‌خواهد
  secret       String?                               // برای امضای HMAC
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([restaurantId, isActive])
  @@map("webhooks")
}

// ── GuestProfile سراسری — نمای cross-restaurant مشتری (شکاف ساختاری CRM) ──
// برخلاف CustomerInsight که per-restaurant است، این پروفایل کلیدش فقط userId
// است: یک مهمان، یک پروفایل در کل پلتفرم. تجمیع‌شده از همه‌ی CustomerInsightها.
// تست‌شده روی PG واقعی (sum/bool_or/array_agg برای رستوران ترجیحی).
model GuestProfile {
  userId              String   @id @map("user_id") @db.Uuid
  globalVisits        Int      @default(0) @map("global_visits")
  globalSpendToman    Int      @default(0) @map("global_spend_toman")
  globalClvToman      Int      @default(0) @map("global_clv_toman")
  restaurantsVisited  Int      @default(0) @map("restaurants_visited")
  lastVisitAnywhere   DateTime? @map("last_visit_anywhere")
  isVipAnywhere       Boolean  @default(false) @map("is_vip_anywhere")
  preferredRestaurantId String? @map("preferred_restaurant_id") @db.Uuid
  dietaryTags         String[] @default([]) @map("dietary_tags")    // آلرژی/رژیم (پیش‌نیاز personalization)
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([isVipAnywhere])
  @@map("guest_profiles")
}

// ── تراکنش‌های SMS — هر شارژ یا مصرف (برای حسابرسی موجودی پیامک) ──
model SmsTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  delta        Int      // مثبت = شارژ، منفی = مصرف
  reason       String   // 'admin_topup' | 'campaign' | 'reservation_notify'
  balanceAfter Int      @map("balance_after")
  actorId      String?  @map("actor_id") @db.Uuid
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")
  @@index([restaurantId, createdAt(sort: Desc)])
  @@map("sms_transactions")
}

// ── نظرات مشتری درباره‌ی رستوران (به رزرو واقعی وصل، هر رزرو یک نظر) ──
model Review {
  id               String       @id @default(uuid()) @db.Uuid
  restaurantId     String       @map("restaurant_id") @db.Uuid
  restaurant       Restaurant   @relation(fields: [restaurantId], references: [id])
  userId           String?      @map("user_id") @db.Uuid
  user             User?        @relation(fields: [userId], references: [id])
  reservationId    String?      @map("reservation_id") @db.Uuid
  reservation      Reservation? @relation(fields: [reservationId], references: [id])
  rating           Int          @db.SmallInt
  foodRating       Int?         @map("food_rating") @db.SmallInt
  serviceRating    Int?         @map("service_rating") @db.SmallInt
  atmosphereRating Int?         @map("atmosphere_rating") @db.SmallInt
  body             String?
  reply            String?
  repliedAt        DateTime?    @map("replied_at")
  isPublished      Boolean      @default(true) @map("is_published")
  createdAt        DateTime     @default(now()) @map("created_at")
  @@index([restaurantId, createdAt(sort: Desc)])
  @@map("reviews")
}

// ── گالری عکس رستوران ──
model RestaurantPhoto {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  url          String
  caption      String?
  category     String     @default("food")
  sortOrder    Int        @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  @@index([restaurantId, sortOrder])
  @@map("restaurant_photos")
}

// ── یادداشت‌های داخلی تیم رستوران ──
model StaffNote {
  id            String     @id @default(uuid()) @db.Uuid
  restaurantId  String     @map("restaurant_id") @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  authorStaffId String?    @map("author_staff_id") @db.Uuid
  authorName    String?    @map("author_name")
  body          String
  pinned        Boolean    @default(false)
  createdAt     DateTime   @default(now()) @map("created_at")
  @@index([restaurantId, pinned(sort: Desc), createdAt(sort: Desc)])
  @@map("staff_notes")
}

// ── تاریخچه‌ی کمپین پیامکی ──
model CampaignLog {
  id              String     @id @default(uuid()) @db.Uuid
  restaurantId    String     @map("restaurant_id") @db.Uuid
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  segment         String
  message         String
  recipientsCount Int        @default(0) @map("recipients_count")
  sentByStaffId   String?    @map("sent_by_staff_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  @@index([restaurantId, createdAt(sort: Desc)])
  @@map("campaign_logs")
}
