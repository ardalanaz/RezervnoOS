# ═══════════════════════════════════════════════════════════
#  رزرونو — متغیرهای محیطی
#  کپی کن به .env و پر کن:  cp .env.example .env
#  ⚠️  .env را در git نگذار (در .gitignore هست)
# ═══════════════════════════════════════════════════════════

# ── دیتابیس ──
POSTGRES_USER=rezervno
POSTGRES_PASSWORD=یک_رمز_قوی_بگذار
POSTGRES_DB=rezervno

# ── کلیدهای JWT (تصادفی و بلند بساز: openssl rand -base64 48) ──
JWT_SECRET=یک_کلید_تصادفی_بلند
JWT_REFRESH_SECRET=یک_کلید_تصادفی_دیگر

# ── حالت OTP ──
# true = کد در پاسخ برمی‌گردد (فقط برای تست بدون پیامک واقعی)
# قبل از لانچ واقعی روی false بگذار
OTP_DEV_MODE=true

# کلید مخفی برای endpointهای نگهداری (انقضای هولد رزرو) — یک رشته تصادفی
MAINTENANCE_KEY=change-me-random-string

# ── seed خودکار ──
# برای اولین راه‌اندازی true بگذار (داده‌ی اولیه: رستوران/مشتری/مدیر)
# بعد از اولین بار، روی false بگذار
RUN_SEED=true

# ── دامنه (فقط برای HTTPS/تولید) ──
# دامنه‌ای که به آی‌پی سرور اشاره می‌کند. Caddy خودکار SSL می‌گیرد.
# فقط وقتی با docker-compose.prod.yml اجرا می‌کنی لازم است.
DOMAIN=

# ── مدیر پلتفرم (پنل شرکت) ──
# بعد از اجرای seed، شناسه‌ی tenant شرکت را اینجا بگذار (seed آن را چاپ می‌کند)
PLATFORM_ADMIN_TENANT_ID=

# ── پیامک کاوه‌نگار (اختیاری — بدون آن فقط لاگ می‌شود) ──
KAVENEGAR_API_KEY=
KAVENEGAR_TPL_OTP=rezervno-otp
KAVENEGAR_TPL_BOOKING=rezervno-booking
KAVENEGAR_TPL_REMINDER=rezervno-reminder
KAVENEGAR_TPL_WELCOME=rezervno-welcome
KAVENEGAR_TPL_CAMPAIGN=rezervno-campaign
KAVENEGAR_TPL_WINBACK=rezervno-winback
# قالب‌های چرخه‌ی حیات رزرو (در پنل کاوه‌نگار تعریف کن)
KAVENEGAR_TPL_WAITLIST=rezervno-waitlist
KAVENEGAR_TPL_PREPARING=rezervno-preparing
KAVENEGAR_TPL_REJECTED=rezervno-rejected
KAVENEGAR_TPL_CANCELLED=rezervno-cancelled
KAVENEGAR_TPL_NOSHOW=rezervno-noshow
KAVENEGAR_TPL_THANKS=rezervno-thanks

# ═══════════════════════════════════════════════════════════
#  بک‌آپ خودکار دیتابیس
# ═══════════════════════════════════════════════════════════
# زمان‌بندی cron (پیش‌فرض: هر روز ۳ بامداد). نمونه‌ها:
#   0 3 * * *     هر روز ۳ بامداد
#   0 */6 * * *   هر ۶ ساعت
#   0 3 * * 0     هر یکشنبه ۳ بامداد
BACKUP_CRON=0 3 * * *

# چند بک‌آپ آخر نگه داشته شود (بقیه خودکار حذف می‌شوند)
BACKUP_KEEP=14

# بک‌آپ فوری هنگام بالا آمدن (پیشنهاد: true)
BACKUP_ON_START=true

# ── آپلود بک‌آپ به آبجکت‌استوریج (اختیاری ولی مهم) ──
# بک‌آپی که فقط روی همان سرور است، با از‌دست‌رفتن سرور می‌رود.
# آبجکت‌استوریج S3-compatible: آروان، لیارا، یا AWS S3
# اگر خالی بگذاری، فقط بک‌آپ محلی گرفته می‌شود.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── اعلان Push (Firebase) و Email — اختیاری، برای لیست انتظار ──
FCM_SERVER_KEY=
EMAIL_API_KEY=
EMAIL_FROM=noreply@rezervno.ir

# قالب‌های SMS لیست انتظار
KAVENEGAR_TPL_WL_JOIN=rezervno-wl-join
KAVENEGAR_TPL_WL_OFFER=rezervno-wl-offer

# ── امنیت: منشأهای مجاز (CSRF defense) — دامنه‌های فرانت، با کاما جدا ──
ALLOWED_ORIGINS=https://rezervno.ir,https://www.rezervno.ir
